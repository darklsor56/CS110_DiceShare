<%- include("partials/header") %>

<section class="listing-detail">
    <h2><%= listing.title %></h2>

    <% if(listing.imageUrl) { %>
        <img class="listing-detail-image" src="<%= listing.imageUrl %>" alt="<%= listing.title %>">
    <% } else { %>
        <div class="listing-image-placeholder">No Image</div>
    <% } %>

    <p><strong>Description:</strong> <%= listing.description %></p>
    <p><strong>Dice Type:</strong> <%= listing.diceType %></p>
    <p><strong>Material:</strong> <%= listing.material %></p>
    <p><strong>Color:</strong> <%= listing.color %></p>
    <p><strong>Condition:</strong> <%= listing.condition %></p>
    <p><strong>Number of Dice:</strong> <%= listing.numberOfDice %></p>
    <p><strong>Preferred Trade:</strong> <%= listing.preferredTrade %></p>
    <p><strong>Location:</strong> <%= listing.location %></p>
    <p><strong>Status:</strong> <%= listing.status %></p>

    <% if(listing.tags && listing.tags.length > 0) { %>
        <p><strong>Tags:</strong> <%= listing.tags.join(", ") %></p>
    <% } %>

    <hr>

    <h3>Owner</h3>
    <p><strong>Username:</strong> <a href="/users/<%= listing.owner._id %>"><%= listing.owner.username %></a></p>
    <p><strong>Owner Rating:</strong> <%= listing.owner.averageRating %> / 5</p>

    <% if (currentUser && currentUser.id === listing.owner._id.toString()) { %>
        <p>You own this listing.</p>

        <a class="button-link" href="/listings/<%= listing._id %>/edit">Edit Listing</a>

        <form action="/listings/<%= listing._id %>/delete" method="POST" class="delete-form">
            <button type="submit" onclick="return confirm('Are you sure you want to delete this listing?');">
                Delete Listing
            </button>
        </form>
    <% } else if(currentUser) { %>
        <section class="trade-request-form-container">
            <h3>Request Trade</h3>

            <% if(requestCreated) { %>
                <p class="success-message">Your trade request was sent.</p>
            <% } %>

            <form action="/listings/<%= listing._id %>/request" method="POST" class="trade-request-form">
                <div class="form-group">
                    <label for="offeredListing">Offer one of your available listings (optional)</label>
                    <select id="offeredListing" name="offeredListing">
                        <option value="">No listing offered</option>
                        <% offerableListings.forEach(offerableListing => { %>
                            <option value="<%= offerableListing._id %>"><%= offerableListing.title %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-group">
                    <label for="message">Message (optional)</label>
                    <textarea id="message" name="message" rows="4" maxlength="500" placeholder="Add a short note for the listing owner"></textarea>
                </div>

                <button type="submit">Send Trade Request</button>
            </form>
        </section>

        <section class="review-form-container">
            <h3>Leave a Review</h3>

            <% if(reviewCreated) { %>
                <p class="success-message">Your review was submitted.</p>
            <% } %>

            <form action="/listings/<%= listing._id %>/reviews" method="POST" class="review-form">
                <div class="form-group">
                    <label for="rating">Rating</label>
                    <select id="rating" name="rating" required>
                        <option value="">Choose a rating</option>
                        <option value="5">5 - Excellent</option>
                        <option value="4">4 - Good</option>
                        <option value="3">3 - Average</option>
                        <option value="2">2 - Poor</option>
                        <option value="1">1 - Very Poor</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="comment">Comment (optional)</label>
                    <textarea id="comment" name="comment" rows="4" maxlength="1000" placeholder="Share your experience with this trader"></textarea>
                </div>

                <button type="submit">Submit Review</button>
            </form>
        </section>
    <% } else { %>
        <p><a href="/login">Log in</a> to request a trade.</p>
        <p><a href="/login">Log in</a> to leave a review.</p>
    <% } %>

    <section class="trader-reviews">
        <h3>Reviews for this trader</h3>
        <%- include("partials/reviews", { reviews }) %>
    </section>

    <section class="similar-listings">
        <h3>Similar Dice Listings</h3>

        <% if(recommendedListings.length === 0) { %>
            <p>No similar listings found yet.</p>
        <% } else { %>
            <div class="recommendation-grid">
                <% recommendedListings.forEach(recommendedListing => { %>
                    <article class="recommendation-card">
                        <h4>
                            <a href="/listings/<%= recommendedListing._id %>"><%= recommendedListing.title %></a>
                        </h4>
                        <p><strong>Dice Type:</strong> <%= recommendedListing.diceType %></p>
                        <p><strong>Material:</strong> <%= recommendedListing.material %></p>
                        <p><strong>Color:</strong> <%= recommendedListing.color %></p>
                        <p><strong>Condition:</strong> <%= recommendedListing.condition %></p>
                        <p><strong>Preferred Trade:</strong> <%= recommendedListing.preferredTrade %></p>
                    </article>
                <% }) %>
            </div>
        <% } %>
    </section>

    <p>
        <a href="/listings">Back to listings</a>
    </p>
</section>

<%- include("partials/footer") %>

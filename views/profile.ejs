<%- include("partials/header") %>

<section class="profile-container">
    <h2><%= user.username %>'s Profile</h2>

    <% if (user.profileImageUrl) { %>
        <img class="profile-avatar" src="<%= user.profileImageUrl %>" alt="<%= user.username %>'s profile image">
    <% } else { %>
        <div class="profile-avatar-placeholder">No Image</div>
    <% } %>

    <% if(isOwnProfile) { %>
        <p><strong>Email:</strong> <%= user.email %></p>
    <% } %>
    <p><strong>Location:</strong> <%= user.location || "No location added yet." %></p>
    <p><strong>Bio:</strong> <%= user.bio || "No bio added yet." %></p>
    <p><strong>Average Rating:</strong> <%= user.averageRating %> / 5</p>
    <p><strong>Completed Trades:</strong> <%= user.completedTradeCount %></p>

    <% if(isOwnProfile) { %>
        <a class="button-link" href="/profile/edit">Edit Profile</a>
    <% } %>

    <hr>

    <section class="profile-listings">
        <h3><%= isOwnProfile ? "My Listings" : `${user.username}'s Listings` %></h3>

        <% if(userListings.length === 0) { %>
            <p><%= isOwnProfile ? "You have not created any dice listings yet." : "This user has not created any dice listings yet." %></p>
            <% if(isOwnProfile) { %>
                <a class="button-link" href="/listings/new">Create Your First Listing</a>
            <% } %>
        <% } else { %>
            <div class="listing-grid">
                <% userListings.forEach(listing => { %>
                    <article class="listing-card">
                        <% if(listing.imageUrl) { %>
                            <img class="listing-card-image" src="<%= listing.imageUrl %>" alt="<%= listing.title %>">
                        <% } else { %>
                            <div class="listing-card-placeholder">No Image</div>
                        <% } %>

                        <h4>
                            <a href="/listings/<%= listing._id %>"><%= listing.title %></a>
                        </h4>

                        <p><strong>Type:</strong> <%= listing.diceType %></p>
                        <p><strong>Material:</strong> <%= listing.material %></p>
                        <p><strong>Color:</strong> <%= listing.color %></p>
                        <p><strong>Condition:</strong> <%= listing.condition %></p>
                        <p><strong>Status:</strong> <%= listing.status %></p>
                        <p><strong>Preferred:</strong> <%= listing.preferredTrade %></p>
                    </article>
                <% }) %>
            </div>
        <% } %>
    </section>

    <section class="profile-reviews">
        <h3>Reviews</h3>
        <%- include("partials/reviews", { reviews }) %>
    </section>
</section>

<%- include("partials/footer") %>

<%- include("partials/header") %>

<section class="auth-container">
    <h2>Verify Two-Factor Code</h2>
    <p>Enter the six-digit demo code printed in the server terminal. The code expires after five minutes.</p>

    <form class="auth-form" action="/verify-2fa" method="POST">
        <div class="form-group">
            <label for="code">Verification Code</label>
            <input
                type="text"
                id="code"
                name="code"
                inputmode="numeric"
                pattern="[0-9]{6}"
                minlength="6"
                maxlength="6"
                autocomplete="one-time-code"
                required
            >
        </div>

        <button type="submit">Verify and Log In</button>
    </form>

    <p class="auth-switch"><a href="/login">Return to login</a></p>
</section>

<%- include("partials/footer") %>
